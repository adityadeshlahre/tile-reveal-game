---
import Layout from '../layouts/Layout.astro';
import MobileBlock from '../components/MobileBlock.astro';
---

<Layout>
  <MobileBlock />
  <div id="game-app" class="max-w-[520px] mx-auto p-8 flex flex-col min-h-screen max-sm:hidden">
    <header class="text-center pb-2">
      <h1 class="text-6xl font-bold tracking-tight text-[#0a0a0a]">Tile Reveal Game</h1>
      <h1 class="text-2xl font-bold tracking-tight text-[#0a0a0a]">Guess Who</h1>
    </header>

    <div id="round-bar" class="flex items-center py-3 min-h-[44px]">
      <span id="round-label" class="font-semibold text-sm text-[#0a0a0a]"></span>
    </div>

    <div class="relative w-full bg-[#0a0a0a] rounded-2xl overflow-hidden shadow-[0_4px_24px_rgba(0,0,0,0.12)]">
      <img id="board-image" class="block w-full bg-[#1a1a1a]" alt="" />
      <div id="tile-grid" class="absolute inset-0 grid gap-0.5 p-0.5"></div>
    </div>

    <div class="text-center py-5">
      <div class="text-xs font-semibold text-[#9a9a9a] uppercase tracking-widest mb-1">Answer</div>
      <div id="answer-text" class="text-[28px] font-bold tracking-tight text-[#0a0a0a] min-h-[34px]">???</div>
    </div>

    <div class="flex gap-3 justify-center py-1 pb-4">
      <button id="btn-prev" class="flex-1 px-3 py-3 rounded-xl font-semibold text-base bg-[#e5e5e5] text-[#0a0a0a] hover:bg-[#d0d0d0] disabled:opacity-30 disabled:cursor-default transition-opacity border-none cursor-pointer font-sans" disabled>Prev</button>
      <button id="btn-reset" class="flex-1 px-3 py-3 rounded-xl font-semibold text-base bg-[#e5e5e5] text-[#0a0a0a] hover:bg-[#d0d0d0] disabled:opacity-30 disabled:cursor-default transition-opacity border-none cursor-pointer font-sans" disabled>Reset</button>
      <button id="btn-reveal-all" class="flex-1 px-3 py-3 rounded-xl font-semibold text-base bg-[#0a0a0a] text-white hover:bg-[#1f1f1f] transition-opacity border-none cursor-pointer font-sans">Reveal All</button>
      <button id="btn-next" class="flex-1 px-3 py-3 rounded-xl font-semibold text-base bg-[#e5e5e5] text-[#0a0a0a] hover:bg-[#d0d0d0] disabled:opacity-30 disabled:cursor-default transition-opacity border-none cursor-pointer font-sans" disabled>Next</button>
    </div>

    <div id="hint-section" class="pb-4">
      <button id="btn-hint" class="w-full px-3 py-2 rounded-xl font-semibold text-sm bg-[#e5e5e5] text-[#0a0a0a] hover:bg-[#d0d0d0] transition-opacity border-none cursor-pointer font-sans mb-2">Get Hint</button>
      <div id="hint-box" class="w-full min-h-[32px] px-3 py-2 rounded-xl bg-[#f5f5f5] text-sm text-[#6a6a6a] italic leading-relaxed hidden"></div>
    </div>
  </div>
</Layout>

<script>
  (() => {
    const TILE_CLASSES = [
      'relative',
      'bg-[linear-gradient(145deg,#3a3a3a,#2e2e2e)]',
      'border',
      'border-[#4a4a4a]',
      'rounded',
      'cursor-pointer',
      'transition-opacity',
      'duration-200',
      'hover:bg-[linear-gradient(145deg,#4a4a4a,#3a3a3a)]',
      'active:bg-[linear-gradient(145deg,#2a2a2a,#1e1e1e)]',
      'after:absolute',
      'after:inset-0',
      "after:bg-[linear-gradient(180deg,rgba(255,255,255,0.05),transparent_50%)]",
      'after:pointer-events-none',
      "after:content-['']",
    ].join(' ');

    const state = {
      config: null,
      currentRound: 0,
      revealedTiles: new Set(),
      hintLoading: false,
    };

    const $ = (id) => document.getElementById(id);
    const el = {
      boardImage: $('board-image'),
      tileGrid: $('tile-grid'),
      answerText: $('answer-text'),
      roundLabel: $('round-label'),
      btnPrev: $('btn-prev'),
      btnNext: $('btn-next'),
      btnRevealAll: $('btn-reveal-all'),
      btnReset: $('btn-reset'),
      btnHint: $('btn-hint'),
      hintBox: $('hint-box'),
    };

    async function loadConfig() {
      const res = await fetch('/game-config.json');
      if (!res.ok) throw new Error('Failed to load game config');
      state.config = await res.json();
    }

    function round() {
      return state.config.rounds[state.currentRound];
    }

    function totalTiles() {
      return state.config.tileCols * state.config.tileRows;
    }

    function renderRound() {
      const r = round();
      const cols = state.config.tileCols;

      el.boardImage.src = r.image;
      el.boardImage.alt = r.answer;
      el.roundLabel.textContent = `Round ${state.currentRound + 1} of ${state.config.rounds.length}`;
      el.answerText.textContent = '???';
      el.btnRevealAll.textContent = 'Reveal All';

      el.tileGrid.style.gridTemplateColumns = `repeat(${cols}, 1fr)`;
      el.tileGrid.innerHTML = '';

      state.revealedTiles.clear();

      for (let i = 0; i < totalTiles(); i++) {
        const tile = document.createElement('button');
        tile.className = TILE_CLASSES;
        tile.dataset.index = i;
        tile.addEventListener('click', () => toggleTile(i));
        el.tileGrid.appendChild(tile);
      }

      el.hintBox.classList.add('hidden');
      el.hintBox.textContent = '';
      updateButtons();
    }

    function toggleTile(index) {
      if (state.revealedTiles.has(index)) {
        state.revealedTiles.delete(index);
      } else {
        state.revealedTiles.add(index);
      }
      const tile = el.tileGrid.children[index];
      tile.classList.toggle('opacity-0', state.revealedTiles.has(index));
      tile.classList.toggle('pointer-events-none', state.revealedTiles.has(index));
      updateButtons();
    }

    function revealAll() {
      for (let i = 0; i < totalTiles(); i++) {
        state.revealedTiles.add(i);
        el.tileGrid.children[i].classList.add('opacity-0', 'pointer-events-none');
      }
      el.answerText.textContent = round().answer;
      el.btnRevealAll.textContent = 'Revealed';
      updateButtons();
    }

    function reset() {
      state.revealedTiles.clear();
      for (const tile of el.tileGrid.children) {
        tile.classList.remove('opacity-0', 'pointer-events-none');
      }
      el.answerText.textContent = '???';
      el.btnRevealAll.textContent = 'Reveal All';
      updateButtons();
    }

    function prevRound() {
      if (state.currentRound > 0) {
        state.currentRound--;
        renderRound();
      }
    }

    function nextRound() {
      if (state.currentRound < state.config.rounds.length - 1) {
        state.currentRound++;
        renderRound();
      }
    }

    function updateButtons() {
      el.btnPrev.disabled = state.currentRound === 0;
      el.btnNext.disabled = state.currentRound === state.config.rounds.length - 1;
      el.btnReset.disabled = state.revealedTiles.size === 0;
    }

    async function getHint() {
      if (state.hintLoading) return;
      const r = round();
      state.hintLoading = true;
      el.btnHint.textContent = 'Loading...';
      el.btnHint.disabled = true;
      el.hintBox.classList.add('hidden');
      try {
        const res = await fetch(`/api/hint?url=${encodeURIComponent(r.hints)}`);
        const data = await res.json();
        if (data.hint) {
          el.hintBox.textContent = data.hint;
          el.hintBox.classList.remove('hidden');
        } else {
          el.hintBox.textContent = data.error || 'Failed to get hint';
          el.hintBox.classList.remove('hidden');
        }
      } catch {
        el.hintBox.textContent = 'Network error';
        el.hintBox.classList.remove('hidden');
      } finally {
        state.hintLoading = false;
        el.btnHint.textContent = 'Get Hint';
        el.btnHint.disabled = false;
      }
    }

    el.btnPrev.addEventListener('click', prevRound);
    el.btnNext.addEventListener('click', nextRound);
    el.btnRevealAll.addEventListener('click', revealAll);
    el.btnReset.addEventListener('click', reset);
    el.btnHint.addEventListener('click', getHint);

    loadConfig()
      .then(() => {
      renderRound();
      updateButtons();
      })
      .catch((err) => {
        el.roundLabel.textContent = 'Error: ' + err.message;
      });
  })();
</script>
